{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2023",
    "rootDir": "./",
    "outDir": "./dist",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["src/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist", "tsup.config.ts"]
}