enum UserRole {
  SUPER_ADMIN   // You (Manages krewOS, billing, platform analytics)
  OWNER         // The Boss of the Construction Company (pays the Stripe bill)
  ADMIN         // HR/Office Manager for the Construction Company
  MEMBER        // Standard worker (gets assigned to projects)
}
enum ProjectRole {
  PROJECT_MANAGER
  SITE_MANAGER
  SAFETY_OFFICER
  SUBCONTRACTOR
  WORKER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WeatherCondition {
  SUNNY
  CLOUDY
  RAINY
  STORMY
  SNOW
}

enum AttendanceMethod {
  MOBILE_APP
  QR_CODE
  NFC_CARD
  MANUAL
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  DELIVERED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum CompanyStatus {
  ACTIVE      // Paying and actively using krewOS
  SUSPENDED   // SUPER_ADMIN hit the kill switch (e.g., TOS violation)
  INACTIVE    // The company voluntarily canceled their account
}
enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}
